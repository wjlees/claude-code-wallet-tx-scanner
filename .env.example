# 노드 접속 설정 (없으면 해당 자산은 스캔 skip)
# 실제 값은 .env (gitignore) 에 둔다.

# EVM: 네트워크 이름(대문자)_NODE_URL
ETHEREUM_NODE_URL=
POLYGON_NODE_URL=
KLAYTN_NODE_URL=
KONET_NODE_URL=

# Solana (SOL + SPL 공용)
SOLANA_RPC_URL=

# Stellar Horizon
STELLAR_HORIZON_URL=

# Bitcoin / Bitcoin Cash (bitcoind 계열 JSON-RPC, 자격증명 포함 가능)
# 예: http://user:pass@host:8332
BITCOIN_RPC_URL=
BCH_RPC_URL=

# Tron (TRX + TRC20 공용, tronweb fullHost, 예: https://api.trongrid.io)
TRON_RPC_URL=

# XRP Ledger (rippled JSON-RPC, 예: https://xrplcluster.com)
XRP_RPC_URL=

# XPLA Chain (Cosmos LCD, 예: https://dimension-lcd.xpla.dev)
XPLA_LCD_URL=
XPLA_CHAIN_ID=
